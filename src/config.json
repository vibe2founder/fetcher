{
  "url": "https://dummyjson.com/users",
  "jwt": "Bearer <token>",
  "entity": "User",
  "responseSchema": {
    "properties": {
      "id": {
        "type": "number"
      },
      "firstName": {
        "type": "string"
      },
      "lastName": {
        "type": "string"
      },
      "birthDate": {
        "type": "date"
      },
      "email": {
        "type": "email"
      }
    }
  }
}